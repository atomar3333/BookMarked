import requests
import json
import mysql.connector

# Fetch works JSON from Open Library
url = "https://openlibrary.org/authors/OL1394865A/works.json"
response = requests.get(url)
data = response.json()
works = data.get("entries", [])

# Connect to MySQL
conn = mysql.connector.connect(
    host="localhost",
    user="root",
    password="Samsung@24",
    database="bookmarked"
)
cursor = conn.cursor()

sql = """
INSERT INTO books (
    open_library_work_id, title, subtitle, description,  
    subjects, authors, covers, identifiers, latest_revision, revision, created, last_modified, cover_image_url, author
) VALUES (%s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s)
ON DUPLICATE KEY UPDATE
    title=VALUES(title),
    subtitle=VALUES(subtitle),
    description=VALUES(description),
    subjects=VALUES(subjects),
    authors=VALUES(authors),
    covers=VALUES(covers),
    identifiers=VALUES(identifiers),
    latest_revision=VALUES(latest_revision),
    revision=VALUES(revision),
    created=VALUES(created),
    last_modified=VALUES(last_modified),
    cover_image_url=VALUES(cover_image_url),
    author=VALUES(author)
"""

for work in works:
    open_library_work_id = work.get("key")
    title = work.get("title")
    subtitle = work.get("subtitle")
    authors_list = work.get("authors", [])
    # Insert first author id (from link) in author column
    if authors_list and "author" in authors_list[0] and "key" in authors_list[0]["author"]:
        author = authors_list[0]["author"]["key"]
    else:
        author = ""
    # Insert all author ids as JSON array in authors column
    authors = json.dumps([a["author"]["key"] for a in authors_list if "author" in a and "key" in a["author"]])
    desc = work.get("description")
    if isinstance(desc, dict):
        description = desc.get("value")
    else:
        description = desc
    subjects = json.dumps(work.get("subjects", []))
    identifiers = json.dumps(work.get("identifiers", {}))
    latest_revision = work.get("latest_revision")
    google_books_id = None  # Not available from Open Library data
    covers_list = work.get("covers", [])
    covers = json.dumps(covers_list)
    revision = work.get("revision")
    cover_image_url = None
    created = work.get("created", {}).get("value") if isinstance(work.get("created"), dict) else work.get("created")
    last_modified = work.get("last_modified", {}).get("value") if isinstance(work.get("last_modified"), dict) else work.get("last_modified")
    if covers_list and isinstance(covers_list, list) and covers_list[0] != -1:
        cover_image_url = f"https://covers.openlibrary.org/b/id/{covers_list[0]}-L.jpg"

    cursor.execute(sql, (
        open_library_work_id, title, subtitle, description, subjects, authors, covers, identifiers, latest_revision, revision, created, last_modified, cover_image_url, author
    ))

conn.commit()
cursor.close()
conn.close()